# =====================================================
# CONFIGURACIÓN DE LA API
# =====================================================
# URL base de la API backend (cambiar según el ambiente)
VITE_API_URL=http://localhost:8080

# =====================================================
# CONFIGURACIÓN DE LA APLICACIÓN
# =====================================================
# Modo de la aplicación (development, production, staging)
VITE_MODE=development
# Modo de debugging/desarrollo (true = mostrar logs detallados)
VITE_DEBUG_MODE=false

# =====================================================
# CONFIGURACIÓN DE AUTENTICACIÓN
# =====================================================
# Nombre de la clave donde se almacena el JWT en localStorage
VITE_TOKEN_KEY=auth_token
# Nombre del usuario actual en localStorage
VITE_USER_KEY=current_user
# Tiempo de reintentos en milisegundos
VITE_RETRY_TIMEOUT=3000
